[layer_names]

3d_physics/layer_1="Default"
3d_physics/layer_2="Walkable"
3d_physics/layer_3="Grabbable"
3d_physics/layer_4="Environment"
3d_physics/layer_7="Player"
3d_physics/layer_8="Head"

[physics]

common/physics_ticks_per_second=90
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/penetration_slop=0.0

[rendering]

textures/canvas_textures/default_texture_filter=2
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
textures/lossless_compression/force_png=true
shading/overrides/force_lambert_over_burley.mobile=false
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/use_debanding=true
vrs/mode=2

[xr]

openxr/enabled=true
openxr/default_action_map="uid://c2h8dr4xfyyi8"
openxr/reference_space=2
openxr/foveation_level=3
openxr/extensions/hand_tracking=true
openxr/extensions/hand_tracking_unobstructed_data_source=true
openxr/extensions/hand_tracking_controller_data_source=true
openxr/extensions/hand_interaction_profile=true
shaders/enabled=true
openxr/extensions/meta/dynamic_resolution=false
openxr/extensions/meta/color_space/starting_color_space=3
openxr/extensions/meta/passthrough=true
openxr/extensions/meta/hand_tracking_aim=true
openxr/extensions/meta/hand_tracking_mesh=true
openxr/extensions/meta/hand_tracking_capsules=true
openxr/extensions/meta/simultaneous_hands_and_controllers=true
